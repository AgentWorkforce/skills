{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["*/persona.ts", "*/agent.ts", "*/lib/*.ts", "shared/*.ts", "workflows/*.ts", "workflows/*.d.ts"],
  "exclude": ["node_modules"]
}
